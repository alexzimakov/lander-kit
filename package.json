{
  "name": "lander-kit",
  "description": "A set of web components to use on your landing pages.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "browserslist": "defaults",
  "scripts": {
    "format": "prettier . --write",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "npm run lint-js && npm run lint-css",
    "lint-js": "eslint \"**/*.js\"",
    "lint-css": "stylelint \"**/*.css\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "storybook": "storybook dev -p 6006 --no-open",
    "build": "rollup --config rollup.config.js",
    "build-storybook": "storybook build",
    "prebuild": "npm run format && npm run lint && npm run typecheck",
    "preversion": "npm run lint && npm run typecheck"
  },
  "author": "Alexander Zimakov (https://github.com/alexzimakov)",
  "license": "MIT",
  "devDependencies": {
    "@babel/cli": "7.23.9",
    "@babel/core": "7.24.0",
    "@babel/eslint-parser": "7.23.10",
    "@babel/preset-env": "7.24.0",
    "@rollup/plugin-babel": "6.0.4",
    "@rollup/plugin-terser": "0.4.4",
    "@storybook/addon-essentials": "7.6.17",
    "@storybook/addon-interactions": "7.6.17",
    "@storybook/addon-links": "7.6.17",
    "@storybook/blocks": "7.6.17",
    "@storybook/html": "7.6.17",
    "@storybook/html-vite": "7.6.17",
    "@storybook/test": "7.6.17",
    "browserslist": "4.23.0",
    "eslint": "8.57.0",
    "eslint-plugin-storybook": "0.8.0",
    "lightningcss": "1.24.0",
    "prettier": "3.2.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "rollup": "4.12.0",
    "storybook": "7.6.17",
    "stylelint": "16.2.1",
    "stylelint-config-hudochenkov": "10.0.0",
    "stylelint-config-standard": "36.0.0",
    "typescript": "5.3.3"
  }
}
